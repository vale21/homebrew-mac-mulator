             if (!virtio_gpu_update_dmabuf(g, scanout_id, res, fb, r)) {
                 virtio_gpu_update_scanout(g, scanout_id, res, fb, r);
             } else {
@@ -651,7 +668,7 @@ static bool virtio_gpu_do_set_scanout(VirtIOGPU *g,
