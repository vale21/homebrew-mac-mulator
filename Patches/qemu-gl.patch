index 0000000000..8beb963cbd
--- /dev/null
+++ b/ui/cocoa/view.m
@@ -0,0 +1,921 @@
+/*
+ * QEMU Cocoa CG display driver
+ *
+ * Copyright (c) 2008 Mike Kronenberg
+ *
